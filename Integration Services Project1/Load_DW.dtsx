    od.quantity,
    od.unit_price,
    od.total_price,
    o.customer_id,
    CAST(CONVERT(VARCHAR(8), o.order_date, 112) AS INT) AS date_key,
    DATEPART(HOUR, o.order_time) * 10000 +
    DATEPART(MINUTE, o.order_time) * 100 +
    DATEPART(SECOND, o.order_time) AS time_key,
    GETDATE() AS accm_txn_create_time,
    CAST(NULL AS DATETIME) AS accm_txn_complete_time,
    CAST(NULL AS FLOAT) AS txn_process_time_hours
FROM dbo.stg_Order_Details od
JOIN dbo.stg_Orders o
    ON od.order_id = o.order_id;</property>
