                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    CAST(CONVERT(VARCHAR(8), order_date, 112) AS INT) AS date_key,
    order_date AS full_date,
    DAY(order_date) AS day_num,
    MONTH(order_date) AS month_num,
    DATENAME(MONTH, order_date) AS month_name,
    DATEPART(QUARTER, order_date) AS quarter_num,
    YEAR(order_date) AS year_num,
    DATENAME(WEEKDAY, order_date) AS day_of_week,
    CASE
        WHEN DATENAME(WEEKDAY, order_date) IN ('Saturday', 'Sunday') THEN 'Yes'
        ELSE 'No'
    END AS weekend_flag
FROM dbo.stg_Orders;</property>
